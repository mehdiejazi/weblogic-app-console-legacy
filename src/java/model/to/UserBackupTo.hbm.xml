<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="model.to">
    <class name="UserBackupTo" table="USER_BACKUP">
        <id name="id" type="long" column="USERBACKUPID">
            <generator class="increment"/>
        </id>
        <property name="UserID" type="long" column="USERID"/>
        <property name="Username" type="java.lang.String" column="USERNAME"/>
        <property name="Reason" type="java.lang.String" column="REASON"/>
        <property name="IP" type="java.lang.String" column="IP"/>
        <property name="GDate" type="java.lang.String" column="GDATE"/>
        <property name="PDate" type="java.lang.String" column="PDATE"/>
        <property name="Time" type="java.lang.String" column="TIME"/>
    </class>
</hibernate-mapping>
