<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="model.to">
    <class name="PagesTo" table="PAGES">
        <id name="id" type="long" column="PAGEID">
            <generator class="increment"/>
        </id>
        <property name="Pagename" type="java.lang.String" column="PAGENAME"/>
        <property name="Pagetitle" type="java.lang.String" column="PAGETITLE"/>
    </class>
</hibernate-mapping>