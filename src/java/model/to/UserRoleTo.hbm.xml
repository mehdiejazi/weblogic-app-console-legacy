<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="model.to">
    <class name="UserRoleTo" table="USER_ROLE">
        <id name="id" type="long" column="USER_ROLEID">
            <generator class="increment"/>
        </id>
        <property name="Username" type="java.lang.String" column="USERNAME"/>
        <property name="Rolename" type="java.lang.String" column="ROLENAME"/>
        <property name="Appname" type="java.lang.String" column="APPNAME"/>
    </class>
</hibernate-mapping>